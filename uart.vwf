<tnetlist_cmd>quartus_eda --write_settings_files=off --simulation --functional=off --flatten_buses=off --timescale=1ps --tool=modelsim_oem --format=verilog --output_directory="C:/Users/user/Desktop/dcsystem/DC-uart-project/simulation/qsim/" uart -c uart</tnetlist_cmd>
<modelsim_script>onerror {exit -code 1}
