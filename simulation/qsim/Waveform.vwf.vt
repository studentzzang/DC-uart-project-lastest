`timescale 1 ps/ 1 ps
module top_vlg_vec_tst();
// constants                                           
// general purpose registers
reg 0;
reg clk;
reg [3:0] data_in;
reg data_ready;
reg noise;
reg reset;
// wires                                               
wire baud_tick;
wire [3:0] data_out;
wire [2:0] rx_cnt;
wire [2:0] tx_cnt;
wire [1:0] tx_sel;
wire tx_serial;

// assign statements (if any)                          
top i1 (
// port map - connection between master ports and signals/registers   
	.\0 (0),
	.baud_tick(baud_tick),
	.clk(clk),
	.data_in(data_in),
	.data_out(data_out),
	.data_ready(data_ready),
	.noise(noise),
	.reset(reset),
	.rx_cnt(rx_cnt),
	.tx_cnt(tx_cnt),
	.tx_sel(tx_sel),
	.tx_serial(tx_serial)
);
initial 
begin 
#3000000 $finish;
end 

// 0
initial
begin
	0 = 1'b0;
end 

// clk
always
begin
	clk = 1'b0;
	clk = #5000 1'b1;
	#5000;
end 
// data_in[ 3 ]
initial
begin
	data_in[3] = 1'b1;
end 
// data_in[ 2 ]
initial
begin
	data_in[2] = 1'b1;
end 
// data_in[ 1 ]
initial
begin
	data_in[1] = 1'b0;
end 
// data_in[ 0 ]
initial
begin
	data_in[0] = 1'b1;
end 

// data_ready
initial
begin
	data_ready = 1'b0;
	data_ready = #20000 1'b1;
	data_ready = #160000 1'b0;
end 

// noise
initial
begin
	noise = 1'b0;
end 

// reset
initial
begin
	reset = 1'b1;
	reset = #20000 1'b0;
end 
endmodule

