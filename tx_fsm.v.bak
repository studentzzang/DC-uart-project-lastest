// synthesis message_off 10175

`timescale 1ns/1ns

module tx_fsm (
    reset,clock,baud_tick,data_ready,tx_bit_7,
    tx_load_data,tx_clear_bit,tx_count_en,tx_out_sel[1:0]);

    input reset;
    input clock;
    input baud_tick;
    input data_ready;
    input tx_bit_7;
    tri0 reset;
    tri0 baud_tick;
    tri0 data_ready;
    tri0 tx_bit_7;
    output tx_load_data;
    output tx_clear_bit;
    output tx_count_en;
    output [1:0] tx_out_sel;
    reg tx_load_data;
    reg tx_clear_bit;
    reg tx_count_en;
    reg [1:0] tx_out_sel;
    reg [3:0] fstate;
    reg [3:0] reg_fstate;
    parameter START=0,DATA=1,IDLE=2,STOP=3;

    always @(posedge clock)
    begin
        if (clock) begin
            fstate <= reg_fstate;
        end
    end

    always @(fstate or reset or baud_tick or data_ready or tx_bit_7)
    begin
        if (reset) begin
            reg_fstate <= IDLE;
            tx_load_data <= 1'b0;
            tx_clear_bit <= 1'b0;
            tx_count_en <= 1'b0;
            tx_out_sel <= 2'b00;
        end
        else begin
            tx_load_data <= 1'b0;
            tx_clear_bit <= 1'b0;
            tx_count_en <= 1'b0;
            tx_out_sel <= 2'b00;
            case (fstate)
                START: begin
                    if (baud_tick)
                        reg_fstate <= DATA;
                    else if (~(baud_tick))
                        reg_fstate <= START;
                    // Inserting 'else' block to prevent latch inference
                    else
                        reg_fstate <= START;

                    tx_clear_bit <= 1'b1;

                    tx_out_sel <= 2'b01;
                end
                DATA: begin
                    if ((baud_tick & tx_bit_7))
                        reg_fstate <= STOP;
                    else if (~((baud_tick & tx_bit_7)))
                        reg_fstate <= DATA;
                    // Inserting 'else' block to prevent latch inference
                    else
                        reg_fstate <= DATA;

                    tx_count_en <= 1'b1;

                    tx_out_sel <= 2'b10;
                end
                IDLE: begin
                    if ((baud_tick & data_ready))
                        reg_fstate <= START;
                    else if (~((baud_tick & data_ready)))
                        reg_fstate <= IDLE;
                    // Inserting 'else' block to prevent latch inference
                    else
                        reg_fstate <= IDLE;

                    tx_load_data <= 1'b1;

                    tx_out_sel <= 2'b00;
                end
                STOP: begin
                    if (baud_tick)
                        reg_fstate <= IDLE;
                    else if (~(baud_tick))
                        reg_fstate <= STOP;
                    // Inserting 'else' block to prevent latch inference
                    else
                        reg_fstate <= STOP;

                    tx_out_sel <= 2'b11;
                end
                default: begin
                    tx_load_data <= 1'bx;
                    tx_clear_bit <= 1'bx;
                    tx_count_en <= 1'bx;
                    tx_out_sel <= 2'bxx;
                    $display ("Reach undefined state");
                end
            endcase
        end
    end
endmodule // tx_fsm
